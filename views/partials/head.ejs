<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    padding: 20px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  header {
    text-align: center;
    color: white;
    margin-bottom: 40px;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    font-weight: 700;
  }

  .subtitle {
    font-size: 1rem;
    opacity: 0.9;
  }

  .form-section {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    margin-bottom: 40px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .signup-form-group {
    display: flex;
    flex-direction: column;
    gap: 15px;
    width: 425px;
  }

  .signup-form-section {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    margin-bottom: 40px;
    width: 550px;
    position: center;
  }
  label {
    font-weight: 600;
    color: #333;
    font-size: 0.95rem;
  }

  .input-wrapper {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  input[type="text"] {
    flex: 1;
    min-width: 200px;
    padding: 12px 16px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  input[type="text"]:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .btn-generate {
    padding: 12px 28px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .btn-generate:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
  }

  .btn-generate:active {
    transform: translateY(0);
  }

  .success-message {
    background: #d4edda;
    color: #155724;
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
    border-left: 4px solid #28a745;
    font-weight: 500;
    display: flexbox;
  }
  .copy-btn-copy {
    background: #4caf50;
    color: white;
    height: auto;
    width: auto;
    display: flex-end;
  }

  .copy-btn-copy:hover {
    transform: translateY(-2px);
  }

  .copy-btn-copy:active {
    transform: translateY(0);
  }

  .urls-section {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .urls-section h2 {
    margin-bottom: 20px;
    color: #333;
    font-size: 1.5rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: #f8f9fa;
    border-bottom: 2px solid #e0e0e0;
  }

  th {
    padding: 15px;
    text-align: left;
    font-weight: 600;
    color: #333;
    font-size: 0.95rem;
  }

  td {
    padding: 15px;
    border-bottom: 1px solid #e0e0e0;
    color: #555;
  }

  tbody tr {
    transition: background-color 0.2s ease;
  }

  tbody tr:hover {
    background-color: #f8f9fa;
  }

  .short-id {
    font-family: "Courier New", monospace;
    font-weight: 600;
    color: #667eea;
  }

  .clicks-badge {
    display: inline-block;
    background: #e3f2fd;
    color: #1976d2;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .action-buttons {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  button {
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .copy-btn {
    background: #4caf50;
    color: white;
  }

  .copy-btn:hover {
    background: #45a049;
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(76, 175, 80, 0.3);
  }

  .copy-btn:active {
    transform: translateY(0);
  }

  .delete-btn {
    background: #f44336;
    color: white;
  }

  .delete-btn:hover {
    background: #da190b;
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(244, 67, 54, 0.3);
  }

  .delete-btn:active {
    transform: translateY(0);
  }

  .signup-btn {
    background: #4caf50;
    color: white;
    padding: 12px 28px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .signup-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
  }

  .signup-btn:active {
    transform: translateY(0);
  }

  .auth-page {
    min-height: calc(100vh - 40px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .auth-card {
    width: min(960px, 100%);
    display: flex;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.18);
    background: white;
  }

  .auth-card--login {
    flex-direction: row-reverse;
  }

  .auth-info-panel {
    flex: 1;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 16px;
  }

  .auth-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .auth-info-panel h2 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .auth-info-panel p {
    opacity: 0.9;
    line-height: 1.6;
  }

  .auth-feature-list {
    list-style: none;
    margin-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-weight: 500;
  }

  .signup-form-section.auth-form-panel {
    flex: 1;
    margin-bottom: 0;
    border-radius: 0;
    box-shadow: none;
    width: auto;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .auth-brand {
    font-size: 0.95rem;
    font-weight: 700;
    color: #667eea;
    margin-bottom: 24px;
  }

  .auth-form-panel h1 {
    font-size: 1.9rem;
    color: #1f2937;
    margin-bottom: 6px;
  }

  .auth-subtitle {
    color: #6b7280;
    margin-bottom: 24px;
    font-size: 0.98rem;
  }

  .signup-form-group {
    width: 100%;
  }

  .signup-form-group input[type="text"],
  .signup-form-group input[type="email"],
  .signup-form-group input[type="password"] {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    font-size: 1rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .signup-form-group input[type="text"]:focus,
  .signup-form-group input[type="email"]:focus,
  .signup-form-group input[type="password"]:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.14);
  }

  .auth-form-panel .signup-btn {
    width: 100%;
    margin-top: 6px;
  }

  .auth-form-panel .signup-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .form-status {
    min-height: 20px;
    margin-top: 6px;
    font-size: 0.9rem;
  }

  .form-status--error {
    color: #dc2626;
  }

  .form-status--success {
    color: #15803d;
  }

  .auth-link {
    margin-top: 18px;
    color: #4b5563;
    text-align: center;
    font-size: 0.95rem;
  }

  .auth-link a {
    color: #5b4bc4;
    text-decoration: none;
    font-weight: 600;
  }

  .auth-link a:hover {
    text-decoration: underline;
  }

  .field-error {
    min-height: 16px;
    margin-top: -8px;
    font-size: 0.83rem;
    color: #dc2626;
  }

  .input-invalid {
    border-color: #dc2626 !important;
    box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.12) !important;
  }

  .input-valid {
    border-color: #16a34a !important;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.12) !important;
  }

  .empty-state {
    text-align: center;
    padding: 40px;
    color: #999;
  }

  .empty-state p {
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }

    .auth-card,
    .auth-card--login {
      flex-direction: column;
    }

    .auth-info-panel,
    .signup-form-section.auth-form-panel {
      padding: 28px 24px;
    }

    .auth-page {
      min-height: auto;
    }

    .form-section,
    .urls-section {
      padding: 20px;
    }

    .input-wrapper {
      flex-direction: column;
    }

    input[type="text"] {
      min-width: 100%;
    }

    .btn-generate {
      width: 100%;
    }

    table {
      font-size: 0.9rem;
    }

    th,
    td {
      padding: 12px 8px;
    }

    .action-buttons {
      flex-direction: column;
    }

    button {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    body {
      padding: 10px;
    }

    h1 {
      font-size: 1.5rem;
    }

    .form-section,
    .urls-section {
      padding: 15px;
      border-radius: 8px;
    }

    th,
    td {
      padding: 10px 5px;
    }

    .short-id {
      word-break: break-all;
    }
  }
</style>
